<%- include('../partials/header') %>
<div class="page-title">
  <div><h1 class="h3 mb-1"><%= student.full_name %></h1><div class="page-subtitle"><%= student.group_name %> · личная карточка студента</div></div>
  <% if (user.role !== 'viewer') { %><a class="btn btn-outline-primary" href="/students/<%= student.id %>/edit">Редактировать</a><% } %>
</div>
<div class="row g-4">
  <div class="col-lg-6"><div class="card h-100"><div class="card-header">Карточка студента</div><div class="card-body">
    <div class="info-line"><b>Группа</b><span><%= student.group_name %></span></div>
    <div class="info-line"><b>Дата рождения</b><span><%= student.birth_date ? student.birth_date.toISOString().slice(0,10) : '' %></span></div>
    <div class="info-line"><b>Телефон</b><span><%= student.phone || '' %></span></div>
    <div class="info-line"><b>Email</b><span><%= student.email || '' %></span></div>
    <div class="info-line"><b>Адрес</b><span><%= student.address || '' %></span></div>
    <div class="info-line"><b>Статус</b><span class="badge <%= student.status === 'active' ? 'badge-status-active' : 'badge-soft' %>"><%= statusLabel(student.status) %></span></div>
    <div class="mt-3"><b>Примечание:</b><p class="text-muted mb-0"><%= student.notes || 'Нет примечаний' %></p></div>
  </div></div></div>
  <div class="col-lg-6"><div class="card h-100"><div class="card-header">Родители и представители</div><div class="card-body">
    <% parents.forEach(p => { %><div class="border-bottom py-3"><b><%= p.full_name %></b><br><span class="text-muted"><%= p.relation_type %> · <%= p.phone || '' %> · <%= p.email || '' %></span></div><% }) %>
    <% if (!parents.length) { %><div class="empty-state">Представители ещё не добавлены</div><% } %>
    <% if (user.role !== 'viewer') { %>
    <form method="post" action="/students/<%= student.id %>/parents" class="row g-2 mt-3">
      <div class="col-md-6"><input class="form-control" name="full_name" placeholder="ФИО представителя *" required minlength="8" pattern="[^0-9]+" title="ФИО не должно содержать цифры"></div>
      <div class="col-md-6"><input class="form-control" name="relation_type" placeholder="Кем приходится *" required></div>
      <div class="col-md-6"><input class="form-control" type="tel" name="phone" placeholder="Телефон *" required minlength="10"></div>
      <div class="col-md-6"><input class="form-control" type="email" name="email" placeholder="Email *" required></div>
      <div class="col-12"><button class="btn btn-sm btn-primary">Добавить представителя</button></div>
    </form>
    <% } %>
  </div></div></div>
</div>
<div class="row g-4 mt-1">
  <div class="col-lg-6"><div class="card"><div class="card-header">Успеваемость</div><div class="card-body p-0"><table class="table mb-0"><tbody><% grades.forEach(g => { %><tr><td><%= g.subject_name %></td><td><b><%= g.grade_value %></b></td><td><%= g.grade_date.toISOString().slice(0,10) %></td></tr><% }) %><% if (!grades.length) { %><tr><td class="empty-state">Оценок пока нет</td></tr><% } %></tbody></table></div></div></div>
  <div class="col-lg-6"><div class="card"><div class="card-header">Посещаемость</div><div class="card-body p-0"><table class="table mb-0"><tbody><% attendance.forEach(a => { %><tr><td><%= a.subject_name %></td><td><%= attendanceLabel(a.status) %></td><td><%= a.lesson_date.toISOString().slice(0,10) %></td></tr><% }) %><% if (!attendance.length) { %><tr><td class="empty-state">Записей посещаемости пока нет</td></tr><% } %></tbody></table></div></div></div>
</div>
<%- include('../partials/footer') %>

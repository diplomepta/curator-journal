<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Электронный журнал куратора</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<% if (user) { %>
<nav class="navbar navbar-expand-lg navbar-dark app-navbar">
  <div class="container-fluid px-3 px-lg-4">
    <a class="navbar-brand d-flex align-items-center" href="/">Журнал куратора</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"><span class="navbar-toggler-icon"></span></button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav me-auto ms-lg-3 gap-lg-1">
        <li class="nav-item"><a class="nav-link" href="/students">Студенты</a></li>
        <li class="nav-item"><a class="nav-link" href="/attendance">Посещаемость</a></li>
        <li class="nav-item"><a class="nav-link" href="/grades">Успеваемость</a></li>
        <li class="nav-item"><a class="nav-link" href="/events">Мероприятия</a></li>
        <li class="nav-item"><a class="nav-link" href="/subjects">Дисциплины</a></li>
        <li class="nav-item"><a class="nav-link" href="/reports">Отчёты</a></li>
        <% if (user.role === 'admin') { %><li class="nav-item"><a class="nav-link" href="/admin/users">Пользователи</a></li><% } %>
      </ul>
      <span class="user-chip me-lg-3 my-2 my-lg-0"><%= user.full_name %> · <%= user.role_title %></span>
      <a class="btn btn-light btn-sm" href="/logout">Выйти</a>
    </div>
  </div>
</nav>
<% } %>
<main class="container py-4">

<%- include('partials/header') %>
<div class="login-page">
  <div class="login-box">
    <div class="card login-panel">
      <div class="login-visual">
        <div class="brand-mark mb-4">Ж</div>
        <h1>Электронный журнал куратора</h1>
        <p class="mt-3">Единая панель для контроля студентов, посещаемости, успеваемости, мероприятий и отчётности группы.</p>
        <div class="row g-3 mt-4">
          <div class="col-6"><div class="p-3 rounded-4" style="background:rgba(255,255,255,.12)"><b>Роли</b><br><span class="text-white-50">админ · куратор · просмотр</span></div></div>
          <div class="col-6"><div class="p-3 rounded-4" style="background:rgba(255,255,255,.12)"><b>Отчёты</b><br><span class="text-white-50">CSV и аналитика</span></div></div>
        </div>
      </div>
      <div class="login-form">
        <h2 class="h4 mb-1">Вход в систему</h2>
        <p class="text-muted mb-4">Введите учётные данные пользователя.</p>
        <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
        <form method="post" action="/login">
          <div class="mb-3">
            <label class="form-label">Логин</label>
            <input class="form-control" name="username" autocomplete="username" required minlength="3">
          </div>
          <div class="mb-3">
            <label class="form-label">Пароль</label>
            <input class="form-control" type="password" name="password" autocomplete="current-password" required minlength="6">
          </div>
          <button class="btn btn-primary w-100">Войти</button>
        </form>
        <div class="small text-muted mt-3">Нет аккаунта? <a href="/register">Зарегистрироваться</a></div>
        <div class="small text-muted mt-4">Тестовые пользователи: admin/admin123, curator/curator123, viewer/viewer123</div>
      </div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
